le
  FROM node:20-alpine
  WORKDIR /app
  RUN apk add --no-cache python3 make g++
  COPY package*.json ./
  RUN npm ci --ignore-scripts
  COPY . .
  RUN npm rebuild better-sqlite3 && npm cache clean --force
  RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001 && chown -R nodejs:nodejs /app
  USER nodejs
  ENV NODE_ENV=production
  ENV PORT=3000
  EXPOSE 3000
  HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 CMD wget --no-verbose --tries=1   
  --spider http://localhost:3000/health || exit 1
  CMD ["node", "src/server/index.js"]
