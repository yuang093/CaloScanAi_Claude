# ============================================
# CaloScanAi 環境變數設定範例
# 複製此檔案為 .env 並填入實際值
# ============================================

# 資料庫設定
DB_USER=caloscanai
DB_PASSWORD=your_secure_password_here
DB_NAME=caloscanai
DB_HOST=postgres
DB_PORT=5432

# JWT 認證（請使用隨機字串，長度至少 32 字元）
JWT_SECRET=your_jwt_secret_key_change_this_in_production_minimum_32_characters

# AI API Key（用於食物辨識）
AI_API_KEY=your_ai_api_key_here

# 預設管理員密碼（首次登入後請立即更改）
ADMIN_PASSWORD=change_this_admin_password

# Node 環境
NODE_ENV=production
PORT=3000

# 應用程式 URL（用於 CORS 和郵件）
APP_URL=https://calo_C.yuang093.cc
ADMIN_EMAIL=admin@caloscanai.com

# 圖片上傳設定
MAX_UPLOAD_SIZE=5242880
IMAGE_QUALITY=0.85
MAX_IMAGE_DIMENSION=1200

# 備份設定
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7

# 日誌等級
LOG_LEVEL=info