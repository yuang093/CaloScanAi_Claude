# CaloScanAi 環境變數設定
# 複製此檔案為 .env 並填入實際值

# JWT 認證（請使用隨機字串，長度至少 32 字元）
# 生產環境必須設定，否則伺服器會拒絕啟動
JWT_SECRET=your_jwt_secret_key_change_this_in_production_minimum_32_characters

# AI API Key（MiniMax API Key）
AI_API_KEY=your_ai_api_key_here

# 預設管理員密碼
ADMIN_PASSWORD=admin123

# Node 環境
NODE_ENV=production
PORT=3000

# 應用程式 URL（用於 CORS，支援逗號分隔多個 origin）
# 格式：完整網域，包含協議（https://）
# 範例：https://calo_C.yuang093.cc
# 生產環境務必設定，否則 CORS 會允許所有來源
APP_URL=https://calo_C.yuang093.cc